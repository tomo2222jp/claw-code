{
  "name": "@claw-code/claw-studio",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n MAIN,RENDERER,ELECTRON -c green,blue,magenta \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.node.build.json --watch",
    "dev:renderer": "vite --host 127.0.0.1 --port 5174",
    "dev:electron": "wait-on dist/main/index.js tcp:5174 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 nodemon --watch dist/main --watch dist/preload --ext js --exec \"node scripts/launch-electron.cjs .\"",
    "build": "npm run typecheck && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.node.build.json",
    "build:renderer": "vite build --base ./",
    "typecheck": "tsc -b",
    "start": "node scripts/launch-electron.cjs ."
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^36.2.1",
    "nodemon": "^3.1.10",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "wait-on": "^8.0.5"
  }
}
