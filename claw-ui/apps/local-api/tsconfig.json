{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "../..",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../../shared/contracts/index.ts"]
}
